<html>
<head>
    <title>AI 문서 생성 - 감사 로그</title>
    <meta name="decorator" content="atl.admin" />
    <link rel="stylesheet" href="$baseUrl/download/resources/$pluginKey:ai-generation-admin-resources/ai-generation-admin.css" type="text/css"/>
</head>
<body>
<div id="ai-gen-admin-container" class="ai-gen-admin">
    <!-- Navigation -->
    <nav class="aui-navgroup aui-navgroup-horizontal">
        <div class="aui-navgroup-inner">
            <div class="aui-navgroup-primary">
                <ul class="aui-nav">
                    <li><a href="$baseUrl/plugins/servlet/ai-generation/admin/config">설정</a></li>
                    <li><a href="$baseUrl/plugins/servlet/ai-generation/admin/prompts">프롬프트</a></li>
                    <li><a href="$baseUrl/plugins/servlet/ai-generation/admin/policies">정책</a></li>
                    <li class="aui-nav-selected"><a href="$baseUrl/plugins/servlet/ai-generation/admin/audit">감사 로그</a></li>
                </ul>
            </div>
        </div>
    </nav>

    <div class="ai-gen-admin-panel">
        <!-- Usage Statistics -->
        <h2>사용량 현황</h2>
        <div class="field-group">
            <label for="ai-gen-usage-days">조회 기간</label>
            <select id="ai-gen-usage-days" class="select">
                <option value="1">오늘</option>
                <option value="7" selected>최근 7일</option>
                <option value="30">최근 30일</option>
                <option value="90">최근 90일</option>
            </select>
        </div>
        <div id="ai-gen-usage-container"></div>

        <hr/>

        <!-- Audit Log -->
        <h2>감사 로그</h2>
        <p class="description">AI 문서 생성 관련 모든 활동이 기록됩니다.</p>

        <div class="ai-gen-audit-filters">
            <div class="field-group">
                <label for="ai-gen-audit-user">사용자</label>
                <input type="text" id="ai-gen-audit-user" class="text" placeholder="사용자 키"/>
            </div>
            <div class="field-group">
                <label for="ai-gen-audit-action">액션</label>
                <select id="ai-gen-audit-action" class="select">
                    <option value="">전체</option>
                    <option value="GENERATE_SUBMITTED">생성 제출</option>
                    <option value="GENERATE_COMPLETED">생성 완료</option>
                    <option value="GENERATE_FAILED">생성 실패</option>
                    <option value="GENERATE_CANCELLED">생성 취소</option>
                    <option value="PAGE_SAVED">페이지 저장</option>
                    <option value="PAGE_INSERTED">페이지 삽입</option>
                    <option value="CONFIG_UPDATED">설정 변경</option>
                    <option value="API_KEY_UPDATED">API 키 변경</option>
                    <option value="POLICY_SAVED">정책 저장</option>
                    <option value="POLICY_DELETED">정책 삭제</option>
                </select>
            </div>
            <div class="field-group">
                <label for="ai-gen-audit-space">스페이스</label>
                <input type="text" id="ai-gen-audit-space" class="text" placeholder="스페이스 키"/>
            </div>
            <button type="button" id="ai-gen-audit-filter" class="aui-button">조회</button>
        </div>

        <table id="ai-gen-audit-table" class="aui">
            <thead>
                <tr>
                    <th>시간</th>
                    <th>사용자</th>
                    <th>액션</th>
                    <th>스페이스</th>
                    <th>상세</th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>

        <div class="ai-gen-audit-paging">
            <button type="button" id="ai-gen-audit-prev" class="aui-button" disabled>이전</button>
            <span>총 <strong id="ai-gen-audit-total">0</strong>건</span>
            <button type="button" id="ai-gen-audit-next" class="aui-button">다음</button>
        </div>
    </div>
</div>

<script>
AJS.toInit(function() {
    var $ = AJS.$;
    var REST_BASE = AJS.contextPath() + '/rest/ai-generation/1.0';
    var auditOffset = 0;
    var auditLimit = 50;

    function usageSummaryHtml(s) {
        return '<div class="ai-gen-usage-summary">' +
            '<div class="ai-gen-usage-card"><div class="ai-gen-usage-value">' + s.totalRequests + '</div><div class="ai-gen-usage-label">총 요청 수</div></div>' +
            '<div class="ai-gen-usage-card"><div class="ai-gen-usage-value">' + s.totalTokens + '</div><div class="ai-gen-usage-label">총 토큰 수</div></div>' +
            '<div class="ai-gen-usage-card"><div class="ai-gen-usage-value">' + s.activeUsers + '</div><div class="ai-gen-usage-label">활성 사용자</div></div>' +
            '<div class="ai-gen-usage-card"><div class="ai-gen-usage-value">' + s.activeSpaces + '</div><div class="ai-gen-usage-label">활성 스페이스</div></div>' +
            '</div>';
    }

    function auditRowHtml(log) {
        var ts = log.timestamp ? new Date(log.timestamp).toLocaleString('ko-KR') : '-';
        return '<tr>' +
            '<td>' + AJS.escapeHtml(ts) + '</td>' +
            '<td>' + AJS.escapeHtml(log.userKey || '-') + '</td>' +
            '<td><span class="aui-lozenge">' + AJS.escapeHtml(log.action) + '</span></td>' +
            '<td>' + AJS.escapeHtml(log.spaceKey || '-') + '</td>' +
            '<td class="ai-gen-audit-details">' + AJS.escapeHtml(log.details || '') + '</td>' +
            '</tr>';
    }

    function loadUsage() {
        var days = parseInt($('#ai-gen-usage-days').val()) || 7;
        $.ajax({
            url: REST_BASE + '/admin/usage',
            data: {days: days},
            dataType: 'json',
            success: function(summary) {
                $('#ai-gen-usage-container').html(usageSummaryHtml({
                    totalRequests: summary.totalRequests || 0,
                    totalTokens: summary.totalTokens || 0,
                    activeUsers: summary.activeUsers || 0,
                    activeSpaces: summary.activeSpaces || 0
                }));
            },
            error: function() {
                $('#ai-gen-usage-container').html('<p class="description">사용량 데이터를 불러올 수 없습니다.</p>');
            }
        });
    }

    function loadAuditLog() {
        $.ajax({
            url: REST_BASE + '/admin/audit',
            data: {
                offset: auditOffset,
                limit: auditLimit,
                userKey: $('#ai-gen-audit-user').val() || undefined,
                action: $('#ai-gen-audit-action').val() || undefined,
                spaceKey: $('#ai-gen-audit-space').val() || undefined
            },
            dataType: 'json',
            success: function(result) {
                var tbody = $('#ai-gen-audit-table tbody').empty();
                $.each(result.items, function(i, log) {
                    tbody.append(auditRowHtml(log));
                });
                $('#ai-gen-audit-total').text(result.total);
                $('#ai-gen-audit-prev').prop('disabled', auditOffset === 0);
                $('#ai-gen-audit-next').prop('disabled', auditOffset + auditLimit >= result.total);
            },
            error: function() {
                AJS.flag({type: 'error', title: '감사 로그를 불러올 수 없습니다.', close: 'auto'});
            }
        });
    }

    $('#ai-gen-audit-filter').on('click', function() { auditOffset = 0; loadAuditLog(); });
    $('#ai-gen-audit-prev').on('click', function() { auditOffset = Math.max(0, auditOffset - auditLimit); loadAuditLog(); });
    $('#ai-gen-audit-next').on('click', function() { auditOffset += auditLimit; loadAuditLog(); });
    $('#ai-gen-usage-days').on('change', loadUsage);

    loadUsage();
    loadAuditLog();
});
</script>
</body>
</html>
